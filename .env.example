# IntaSend
# VITE_INTASEND_PUBLISHABLE_KEY is read at build time by the browser SDK (intasend-inlinejs-sdk) —
# set it in .env locally, and as a build-time env var in Cloudflare's build pipeline in production.
VITE_INTASEND_PUBLISHABLE_KEY=""
# INTASEND_WEBHOOK_CHALLENGE is the shared secret IntaSend includes in webhook payloads — set the
# same value in IntaSend's dashboard webhook config. Set it in .dev.vars locally, and via
# `wrangler secret put INTASEND_WEBHOOK_CHALLENGE` in production.
INTASEND_WEBHOOK_CHALLENGE=""

# Admin
ADMIN_EMAIL=""
